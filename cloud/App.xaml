<Application x:Class="cloud.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:cloud"
             xmlns:view="clr-namespace:cloud.MVVM.View" 
             xmlns:vms="clr-namespace:cloud.MVVM.ViewModel"
             StartupUri="MVVM/View/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                
                <ResourceDictionary Source="Themes/buttonsTitleBar.xaml"/>
                <ResourceDictionary Source="Themes/MenuButtons.xaml"/>
                <ResourceDictionary Source="Themes/AllButtons.xaml"/>
                <ResourceDictionary Source="Themes/RegisterAndBackButton.xaml"/>
                
                
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vms:FileViewModel}">
                <view:FileView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vms:SettingsViewModel}">
                <view:SettingsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vms:LoginViewModel}">
                <view:LoginView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vms:RegisterViewModel}">
                <view:RegisterView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vms:UserViewModel}">
                <view:UserView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vms:FileUserViewModel}">
                <view:FileUserView/>
            </DataTemplate>


        </ResourceDictionary>
    </Application.Resources>
</Application>
