<UserControl x:Class="cloud.MVVM.View.FileUserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:cloud.MVVM.View" xmlns:fa="http://schemas.fontawesome.io/icons/"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#ffffff">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="6*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
            <ListView FontSize="20"
                  Margin="0,20,0,20"
                  Grid.Row="0"
                  Grid.ColumnSpan="4"
                  HorizontalAlignment="Center"
                  ItemsSource="{Binding CloudFiles}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Nr." Width="50" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="Nazwa pliku"  Width="300" DisplayMemberBinding="{Binding FileName}"/>
                    <GridViewColumn Header="Data dodania"  Width="150" DisplayMemberBinding="{Binding Date_add}"/>
                    <GridViewColumn Header="Wielkość"  Width="150" DisplayMemberBinding="{Binding Size}"/>
                </GridView>
            </ListView.View>
        </ListView>


        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Grid.Column="0"
                    Grid.Row="2">
            <Button Content="Dodaj Plik"
                    FontSize="20"
                    Width="150"
                    Height="50"
                    Margin="0,0,0,15"
                    Style="{StaticResource AllButtonsStyle }"
                    Command="{Binding AddFIleCommand}"/>
            <TextBlock FontSize="20"
                       Text="{Binding AlertFile}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Foreground="{Binding AlertFileForeground}"
            />
        </StackPanel>
        <StackPanel VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Grid.Column="1"
                    Grid.Row="2">
            <TextBlock Text="Podaj id:"
                       FontSize="20"
                       Margin="0,0,0,5"/>
            <TextBox 
                 FontSize="20"
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 Padding="30,0,0,0"
                 Margin="0,0,0,5"
                 Text="{Binding IdToDOM}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                             AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="user"  
                                            FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>
            <TextBlock Text="Podaj nową nazwe:"
                       TextWrapping="Wrap"
                       FontSize="20"
                       Margin="0,0,0,5"/>
            <TextBox 
                 FontSize="20"
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 Padding="30,0,0,0"
                 Margin="0,0,0,5"
                 Text="{Binding NewName}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                             AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="File"  
                                            FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>
        </StackPanel>
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Grid.Column="2"
                    Grid.Row="2">
            <Button Content="Usuń"
                    FontSize="20"
                    Width="150"
                    Height="50"
                    Margin="0,0,0,15"
                    Style="{StaticResource AllButtonsStyle }"
                    Command="{Binding DeleteCommand}"/>
            <Button Content="Modyfikuj"
                    FontSize="20"
                    Width="150"
                    Height="50"
                    Margin="0,0,0,0"
                    Style="{StaticResource AllButtonsStyle }"
                    Command="{Binding ModificationCommand}"/>
        </StackPanel>
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Grid.Column="3"
                    Grid.Row="2">
            <Button Content="Odśwież"
                    FontSize="20"
                    Width="150"
                    Height="50"
                    Margin="0,0,0,15"
                    Style="{StaticResource AllButtonsStyle }"
                    Command="{Binding RefreshCommand}"/>
            <Button Content="Pobierz plik"
                    FontSize="20"
                    Width="150"
                    Height="50"
                    Style="{StaticResource AllButtonsStyle }"
                    Command="{Binding DownloadCommand}"/>
        </StackPanel>
        
    </Grid>
</UserControl>
