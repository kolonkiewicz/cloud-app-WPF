<UserControl x:Class="cloud.MVVM.View.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:cloud.MVVM.View"
             xmlns:extensions="clr-namespace:cloud.Core" xmlns:fa="http://schemas.fontawesome.io/icons/"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#ffffff">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Row="0"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="300">

            <TextBlock Text="Login:"
                   FontSize="20"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,5"/>
            <TextBox x:Name="login"
                 FontSize="25"
                 FontWeight="Medium"
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 Padding="25,0,0,0"
                 Margin="0,0,0,10"
                 Text="{Binding Username,UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                             AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="User"  
                                            FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>

            <TextBlock Text="Hasło:"
                   FontSize="20"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,5"/>

            <TextBox x:Name="haslo"
                 FontSize="25"
                 FontWeight="Medium"
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 Padding="25,0,0,0"
                 Margin="0,0,0,10"
                 MaxLength="10"
                 Text="{Binding Password,UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                             AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="lock"  
                                                FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>

            <TextBlock Text="Powtórz hasło:"
                   FontSize="20"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,5"/>

            <TextBox x:Name="phaslo"
                 FontSize="25"
                 FontWeight="Medium"
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 Padding="25,0,0,0"
                 MaxLength="10"
                 Text="{Binding PPassword,UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                             AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="lock"  
                                                FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>
        </StackPanel>

        <StackPanel Grid.Row="0"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="300">

            <TextBlock Text="e-mail:"
                   FontSize="20"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,5"/>
            <TextBox x:Name="email"
                 FontSize="25"
                 FontWeight="Medium"
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 Padding="25,0,0,0"
                 Margin="0,0,0,10"
                 Text="{Binding Email,UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                             AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="Envelope"  
                                            FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>

            <TextBlock Text="Imie:"
                   FontSize="20"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,5"/>

            <TextBox x:Name="imie"
                 FontSize="25"
                 FontWeight="Medium"
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 Padding="25,0,0,0"
                 Margin="0,0,0,10"
                 Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                             AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="User"  
                                                FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>

            <TextBlock Text="Nazisko"
                   FontSize="20"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,5"/>

            <TextBox x:Name="nazwisko"
                 FontSize="25"
                 FontWeight="Medium"
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 Padding="25,0,0,0"
                 Text="{Binding Surname,UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                             AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="User"  
                                                FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>

        </StackPanel>


        <StackPanel Grid.Row="3" 
                    Grid.ColumnSpan="2"
                    Orientation="Vertical">
            <TextBlock FontSize="20" 
                       Margin="0,10,0,5"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Text="{Binding AlertRegister}"
                       Foreground="Red"
            />
            <CheckBox Content="Potwierdź reglumain"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Margin="0,5,0,0"
                      IsChecked="{Binding Check}"/>
            <Button Content="Zarejestruj się" 
                Width="300"
                Height="50"
                Margin="0,10,0,5"
                Style="{StaticResource AllButtonsStyle}"
                Command="{Binding RegisterCommand}"/>

            <Button Content="← Powrót do logowania!"
                FontSize="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Style="{StaticResource RegisterAndBackButton}"
                Command="{Binding DataContext.ShowLoginView,RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>

            
        </StackPanel>
        
    </Grid>

</UserControl>
