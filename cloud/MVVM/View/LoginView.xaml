<UserControl x:Class="cloud.MVVM.View.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:cloud.MVVM.View"
             xmlns:fa="http://schemas.fontawesome.io/icons/" 
             xmlns:viewmodel="clr-namespace:cloud.MVVM.ViewModel" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#ffffff">

    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center">
        <TextBlock Text="Login:"
                   FontSize="20"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,5"/>
        <TextBox FontSize="25" 
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 Padding="25,0,0,0"
                 Margin="0,0,0,10"
                 Text="{Binding Username,UpdateSourceTrigger=PropertyChanged}">
            <TextBox.Background>
                <VisualBrush Stretch="None"
                             AlignmentX="Left">
                    <VisualBrush.Visual>
                        <Grid>
                            <fa:FontAwesome Icon="User"  
                                            FontSize="25"/>
                        </Grid>
                    </VisualBrush.Visual>
                </VisualBrush>
            </TextBox.Background>
        </TextBox>

        <TextBlock Text="Hasło:"
                   FontSize="20"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,5"/>

        <TextBox FontSize="25"
                     CaretBrush="LightGray"
                     BorderBrush="DarkGray"
                     BorderThickness="0,0,0,1"
                     VerticalAlignment="Center"
                     Padding="25,0,0,0"
                     Margin="0,0,0,0"
                     Text="{Binding Password,UpdateSourceTrigger=PropertyChanged}">
            <TextBox.Background>
                <VisualBrush Stretch="None"
                             AlignmentX="Left">
                    <VisualBrush.Visual>
                        <Grid>
                            <fa:FontAwesome Icon="lock"  
                                            FontSize="25"/>
                        </Grid>
                    </VisualBrush.Visual>
                </VisualBrush>
            </TextBox.Background>
        </TextBox>

        <TextBlock FontSize="20" 
                   Margin="0,10,0,10"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Text="{Binding AlertLogin}"
                   Foreground="Red"
        />
        <Button Content="Zaloguj się" 
                Width="300"
                Height="50"
                Margin="0,0,0,10"
                Style="{StaticResource AllButtonsStyle}"
                Command="{Binding LoginCommand}"/>
        <Button Content="Nie masz konta? Zarejestruj się!"
                FontSize="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Style="{StaticResource RegisterAndBackButton}"
                Command="{Binding DataContext.ShowRegisterView,RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
    </StackPanel>
</UserControl>