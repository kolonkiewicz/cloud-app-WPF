<Window x:Class="cloud.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cloud" 
        xmlns:extensions="clr-namespace:cloud.Core" 
        xmlns:viewmodel="clr-namespace:cloud.MVVM.ViewModel" 
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="450" Width="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.DataContext>
        <viewmodel:MainViewModel/>
    </Window.DataContext>

    <DockPanel Background="#ffffff">
        <Border Height="40"
                Background="#3700B3"
                DockPanel.Dock="Top">

            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{Binding MoveWindowCommand}"  />
            </Border.InputBindings>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>


                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,10,0"
                            >
                    <Button Content="-"
                            Padding="0,0,0,4"
                            Command="{Binding MinimizeWindowCommand}"
                            />
                    <Button Content="❏"
                            Padding="0,0,0,3"
                            Command="{Binding MaximizeWindowCommand}"/>

                    <Button Content="X"
                            Padding="0,0,0,2"
                            Command="{Binding ShutdownWindowCommand}"/>
                </StackPanel>
            </Grid>
        </Border>


        <Border Width="50"
                HorizontalAlignment="Left"
                Background="#3700B3">

            <Border.Style>
                <Style>
                    <Style.Triggers>
                        <EventTrigger RoutedEvent="Border.MouseEnter">
                            <EventTrigger.Actions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Border.Width)"
                                                To="170"
                                                Duration="0:0:.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger.Actions>
                        </EventTrigger>

                        <EventTrigger RoutedEvent="Border.MouseLeave">
                            <EventTrigger.Actions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Border.Width)"
                                                To="50"
                                                Duration="0:0:.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger.Actions>
                        </EventTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>
                <RadioButton Command="{Binding ShowFileView}">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="file"
                                        Foreground="#ffffff"
                                        FontSize="20"
                                        FontWeight="Normal" 
                                        Margin="7,0,20,0"
                                        Padding="0,2,0,0"/>
                        <TextBlock Text="Pliki" 
                                   Foreground="#ffffff"
                                   FontSize="20"
                                   FontWeight="Normal"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton Command="{Binding ShowSettingsView}">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="Gear"
                                        Foreground="#ffffff"
                                        FontSize="20"
                                        FontWeight="Normal" 
                                        Margin="7,0,20,0"
                                        Padding="0,2,0,0"
                                        x:Name="ikonyust"/>
                        <TextBlock Text="Ustawienia" 
                                   Foreground="#ffffff"
                                   FontSize="20"
                                   FontWeight="Normal"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton IsChecked="{Binding IsLoginButtonChecked}"
                             Command="{Binding ShowLoginView}">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="User"
                                        Foreground="#ffffff"
                                        FontSize="20"
                                        FontWeight="Normal" 
                                        Margin="7,0,20,0"
                                        Padding="0,2,0,0"
                                        x:Name="ikonyulog"/>
                        <TextBlock Text="{Binding NameofLog}" 
                                   Foreground="#ffffff"
                                   FontSize="20"
                                   FontWeight="Normal"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>

        </Border>
        <ContentPresenter Content="{Binding CurrentView}"/>
    </DockPanel>
</Window>