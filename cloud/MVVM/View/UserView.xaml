<UserControl x:Class="cloud.MVVM.View.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:cloud.MVVM.View" xmlns:fa="http://schemas.fontawesome.io/icons/"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#ffffff">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <StackPanel HorizontalAlignment="Left"
                    Margin="40,30,0,0"
                    Grid.Column="0"
                    Grid.Row="1"
                    Width="300">
            <TextBlock Text="{Binding AlertWelcome}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="40"/>
            <TextBlock Text="Nickname:"
                       FontSize="20"
                       Margin="0,30,0,5"/>
            <TextBox x:Name="email"
                     FontSize="25"
                     CaretBrush="LightGray"
                     BorderBrush="DarkGray"
                     BorderThickness="0,0,0,1"
                     VerticalAlignment="Center"
                     Padding="30,0,0,0"
                     IsReadOnly="True"
                     Text="{Binding Username}">
                    <TextBox.Background>
                        <VisualBrush Stretch="None"
                                         AlignmentX="Left">
                            <VisualBrush.Visual>
                                <Grid>
                                <fa:FontAwesome Icon="User"  
                                                        FontSize="25"/>
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </TextBox.Background>
            </TextBox>
            <TextBlock Text="Imie:"
                       FontSize="20"
                       Margin="0,15,0,5"/>
            <TextBox 
                 FontSize="25"
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 IsReadOnly="True"
                 Padding="30,0,0,0"
                 Text="{Binding Name}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                             AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="User"  
                                            FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>
            <TextBlock Text="Nazwisko:"
                       FontSize="20"
                       Margin="0,15,0,5"/>
            <TextBox 
                 FontSize="25"
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 Padding="30,0,0,0"
                 IsReadOnly="True"
                 Text="{Binding Surname}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                             AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="User"  
                                            FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left"
                    Margin="30,30,0,0"
                    Grid.Column="1"
                    Grid.Row="0">
            <TextBlock FontSize="40"/>
            <TextBlock Text="Hasło:"
                       FontSize="20"
                       Margin="0,30,0,5"/>
            <TextBox 
                     FontSize="25"
                     CaretBrush="LightGray"
                     BorderBrush="DarkGray"
                     BorderThickness="0,0,0,1"
                     VerticalAlignment="Center"
                     Padding="30,0,0,0"
                     IsReadOnly="True"
                     Text="{Binding Password}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                                         AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="lock"  
                                                FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>
            <TextBlock Text="E-mail:"
                       FontSize="20"
                       Margin="0,15,0,5"/>
            <TextBox 
                 FontSize="25"
                 CaretBrush="LightGray"
                 BorderBrush="DarkGray"
                 BorderThickness="0,0,0,1"
                 VerticalAlignment="Center"
                 Padding="30,0,0,0"
                 IsReadOnly="True"
                 Text="{Binding Email}">
                <TextBox.Background>
                    <VisualBrush Stretch="None"
                             AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Grid>
                                <fa:FontAwesome Icon="Envelope"  
                                            FontSize="25"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>
            <Button Content="Wyloguj się" 
                Width="300"
                Height="50"
                Margin="0,37,0,0"
                Style="{StaticResource AllButtonsStyle}"
                Command="{Binding Loqout}"/>

        </StackPanel>


    </Grid>
</UserControl>
